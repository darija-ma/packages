{
  "name": "@darija/humanize-duration",
  "version": "0.1.1",
  "description": "Darija duration humanizer built on top of humanize-duration.",
  "license": "MIT",
  "keywords": [
    "darija",
    "moroccan-arabic",
    "humanize-duration",
    "duration",
    "i18n",
    "localization"
  ],
  "homepage": "https://github.com/darija-ma/packages/tree/main/packages/humanize-duration",
  "bugs": {
    "url": "https://github.com/darija-ma/packages/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/darija-ma/packages.git",
    "directory": "packages/humanize-duration"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "check": "bun run typecheck && bun test && bun run build",
    "prepack": "bun run check",
    "test": "bun test",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "humanize-duration": "^3.33.2"
  },
  "devDependencies": {
    "@types/bun": "^1.3.0",
    "@types/humanize-duration": "^3.27.4",
    "typescript": "^5.9.3"
  }
